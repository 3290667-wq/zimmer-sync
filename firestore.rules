rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Helper Functions
    // ===============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Admin check - uses role from users collection OR verified admin emails
    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          isAdminEmail());
    }

    // Check if email is in admin list (stored in config collection)
    function isAdminEmail() {
      return request.auth.token.email_verified == true &&
        exists(/databases/$(database)/documents/config/admins) &&
        request.auth.token.email in get(/databases/$(database)/documents/config/admins).data.emails;
    }

    // Validate string size and content (basic XSS prevention)
    function isValidString(val, max) {
      return val is string &&
             val.size() <= max &&
             !val.matches('.*<script.*') &&
             !val.matches('.*javascript:.*');
    }

    // Validate phone number format (Israeli format)
    function isValidPhone(val) {
      return !('contactInfo' in val) ||
             (val.contactInfo is string &&
              val.contactInfo.size() <= 20 &&
              val.contactInfo.matches('^[0-9\\-\\+\\s\\(\\)]*$'));
    }

    // Validate Zimmer Unit Data
    function isValidUnit(unit) {
      return unit.keys().hasAll(['id', 'name', 'beds', 'rooms']) &&
             unit.id is string && unit.id.size() <= 50 &&
             isValidString(unit.name, 100) &&
             unit.beds is number && unit.beds >= 1 && unit.beds <= 50 &&
             unit.rooms is number && unit.rooms >= 1 && unit.rooms <= 20 &&
             (!('price' in unit) || isValidString(unit.price, 50)) &&
             (!('notes' in unit) || isValidString(unit.notes, 500));
    }

    // Validate units array (max 5 units)
    function isValidUnits(data) {
      return !('units' in data) ||
             (data.units is list &&
              data.units.size() <= 5);
    }

    // Validate Zimmer Data
    function isValidZimmer(data) {
      return data.keys().hasAll(['name', 'location']) &&
             isValidString(data.name, 100) &&
             isValidString(data.location, 100) &&
             isValidPhone(data) &&
             (!('notes' in data) || isValidString(data.notes, 1000)) &&
             (!('price' in data) || isValidString(data.price, 50)) &&
             isValidUnits(data);
    }

    // Validate Request Data
    function isValidRequest(data) {
      return data.keys().hasAll(['customerName', 'dates']) &&
             isValidString(data.customerName, 100) &&
             isValidString(data.dates, 100) &&
             isValidPhone(data) &&
             (!('locationPref' in data) || isValidString(data.locationPref, 100)) &&
             (!('budget' in data) || isValidString(data.budget, 50)) &&
             (!('notes' in data) || isValidString(data.notes, 500));
    }

    // Check if only claim-related fields are being modified
    function isOnlyClaimUpdate() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(['claimedBy', 'updatedAt']);
    }

    // ===============================================================
    // Config Collection (Admin only)
    // ===============================================================

    match /config/{configId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // ===============================================================
    // Users Collection
    // ===============================================================

    match /users/{userId} {
      // Users can only read their own profile, admins can read all
      allow read: if isOwner(userId) || isAdmin();
      // Users can only write their own profile
      allow write: if isOwner(userId);
    }

    // ===============================================================
    // Zimmers Collection
    // ===============================================================

    match /zimmers/{zimmerId} {
      // Allow public read access for zimmers (guests can view)
      allow read: if true;
      allow create: if isAuthenticated() && isValidZimmer(request.resource.data);
      allow update: if isAuthenticated() &&
                       (isAdmin() || request.auth.uid == resource.data.ownerUid) &&
                       isValidZimmer(request.resource.data);
      allow delete: if isAuthenticated() && (isAdmin() || request.auth.uid == resource.data.ownerUid);
    }

    // ===============================================================
    // Requests Collection
    // ===============================================================

    match /requests/{requestId} {
      // Only authenticated users can read requests (removed public access)
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidRequest(request.resource.data);
      // Allow update by: admin, creator (with validation), or any authenticated user for claim/unclaim only
      allow update: if isAuthenticated() && (
        // Admin can update anything
        isAdmin() ||
        // Creator can update with validation
        (request.auth.uid == resource.data.createdBy && isValidRequest(request.resource.data)) ||
        // Any authenticated user can claim/unclaim (only claimedBy and updatedAt fields)
        isOnlyClaimUpdate()
      );
      allow delete: if isAuthenticated() && (isAdmin() || request.auth.uid == resource.data.createdBy);
    }
  }
}
