{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "description": "Information about a registered user",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "role": { "type": "string", "enum": ["owner", "agent", "admin"] }
      },
      "required": ["userId", "email"]
    },
    "Zimmer": {
      "title": "Zimmer",
      "description": "Vaction rental availability",
      "type": "object",
      "properties": {
        "ownerUid": { "type": "string" },
        "name": { "type": "string" },
        "location": { "type": "string" },
        "rooms": { "type": "number" },
        "beds": { "type": "number" },
        "price": { "type": "string" },
        "contactInfo": { "type": "string" },
        "notes": { "type": "string" },
        "dates": { "type": "string" },
        "disabledDates": { 
          "type": "array",
          "items": { "type": "string" },
          "description": "List of dates which are already booked"
        },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "location"]
    },
    "CustomerRequest": {
      "title": "CustomerRequest",
      "description": "A request for a zimmer",
      "type": "object",
      "properties": {
        "customerName": { "type": "string" },
        "locationPref": { "type": "string" },
        "dates": { "type": "string" },
        "roomsNeeded": { "type": "number" },
        "bedsNeeded": { "type": "number" },
        "budget": { "type": "string" },
        "contactInfo": { "type": "string" },
        "notes": { "type": "string" },
        "createdBy": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["customerName", "dates"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "Storage for user profile information"
    },
    "/zimmers/{zimmerId}": {
      "schema": "Zimmer",
      "description": "Storage for available zimmers"
    },
    "/requests/{requestId}": {
      "schema": "CustomerRequest",
      "description": "Storage for customer requests"
    }
  }
}
